					"numinlets" : 1,
					"numoutlets" : 0,
					"patching_rect" : [ 576.0, 419.0, 372.0, 20.0 ],
					"text" : "logit_a(x): atanh((((x+1)*tanh(a*(1-b)))+((1-x)*tanh(a*(-1-b))))/2)/a+b",
					"textcolor" : [ 0.968627450980392, 0.968627450980392, 0.968627450980392, 1.0 ]
				}

